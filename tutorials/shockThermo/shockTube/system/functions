FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      functions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#includeFunc mag(U)

probeCenter
{
    type            probes;
    libs            ("libsampling.so");

    writeControl    timeStep;
    writeInterval   1;

    probeLocations
    (
        (0 0 0)
    );

    fields
    (
        p
        T
        Tve
        rho
    );
}

